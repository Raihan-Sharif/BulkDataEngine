<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <security>
      <!-- Configure request filtering for large payloads in IIS -->
      <requestFiltering>
        <!-- maxAllowedContentLength is in bytes. ~1 GB = 1073741824 bytes -->
        <requestLimits maxAllowedContentLength="1073741824" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
