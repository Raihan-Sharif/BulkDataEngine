@{
    ViewData["Title"] = "Bulk Data Engine";
    var s = ViewBag.Settings as BulkDataEngine.Models.ConverterSettings;
    var maxMB = s?.MaxFileSizeMB ?? 500;
    var maxExcelMB = s?.MaxExcelFileSizeMB ?? 50;
    var defaultConnName = (string)(ViewBag.DefaultConnectionName);
    var connections = ViewBag.Connections as Dictionary<string, string>;
}

<div class="app-wrapper">

    <!-- â•â• HEADER â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <header class="app-header">
        <div class="header-inner">
            <div class="brand">
                <div class="brand-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <ellipse cx="12" cy="5" rx="9" ry="3" />
                        <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
                        <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
                    </svg>
                </div>
                <div>
                    <h1 class="brand-title">Bulk Data Engine</h1>
                    <p class="brand-sub">Convert TXT &nbsp;&bull;&nbsp; Import CSV / Excel &nbsp;&bull;&nbsp; Bulk Insert to SQL Server</p>
                </div>
            </div>
            <div class="header-badges">
                <span class="badge-pill">Up to @maxMB MB</span>
                <span class="badge-pill">Text-Safe Numerics</span>
                <span class="badge-pill">SqlBulkCopy</span>
            </div>
        </div>
    </header>

    <main class="app-main">

        <!-- â•â• DATABASE CONNECTION (shared) â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
        <div class="panel conn-panel">
            <div class="panel-header">
                <svg class="panel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 10h-1.26A8 8 0 109 20h9a5 5 0 000-10z" />
                </svg>
                <h2>Database Connection</h2>
                <span class="panel-sub">SQL Server</span>
            </div>
            <div class="field-group">
                <label class="field-label">Select Environment</label>
                <select id="connEnvSelect" class="styled-select" style="margin-bottom: 12px; font-weight: 600;">
                    @if (connections != null)
                    {
                        foreach (var kvp in connections)
                        {
                            if (kvp.Key == defaultConnName)
                            {
                                <option value="@kvp.Value" selected>@kvp.Key (Default)</option>
                            }
                            else
                            {
                                <option value="@kvp.Value">@kvp.Key</option>
                            }
                        }
                    }
                    <option value="custom">Custom Connection...</option>
                </select>
            </div>
            <div id="customConnWrap">
                <label class="field-label" id="connLabel">Connection String Value</label>
                <input type="text" id="customConnStr" class="styled-input conn-input"
                       placeholder="Enter connection string manually..." readonly />
                <p class="field-hint" id="connHint">Value fetched from appsettings. Select "Custom" to override manually.</p>
            </div>
        </div>

        <!-- -->
        <div class="tab-nav">
            <button class="tab-btn active" data-tab="convert">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="23,4 23,10 17,10" />
                    <polyline points="1,20 1,14 7,14" />
                    <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15" />
                </svg>
                Convert TXT
            </button>
            <button class="tab-btn" data-tab="import">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="8,17 12,21 16,17" />
                    <line x1="12" y1="12" x2="12" y2="21" />
                    <path d="M20.88 18.09A5 5 0 0018 9h-1.26A8 8 0 103 16.29" />
                </svg>
                Import CSV / Excel
            </button>
        </div>

        <!-- â•â• TAB: CONVERT TXT  -->
        <div id="tab-convert" class="tab-pane active">
            <div class="converter-grid">

                <!-- Config panel -->
                <div class="panel config-panel">
                    <div class="panel-header">
                        <svg class="panel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="3" />
                            <path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14" />
                        </svg>
                        <h2>Configuration</h2>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Column Delimiter</label>
                        <div class="delimiter-row">
                            <select id="delimiterSelect" class="styled-select">
                                <option value="~">~ Tilde (default)</option>
                                <option value="|">| Pipe</option>
                                <option value=";">; Semicolon</option>
                                <option value=",">, Comma</option>
                                <option value="tab">-> Tab</option>
                                <option value="custom">Custom</option>
                            </select>
                            <input type="text" id="customDelimiter" class="styled-input custom-delim-input hidden"
                                   placeholder="Enter delimiter" maxlength="5" />
                        </div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Output Format</label>
                        <div class="format-toggle">
                            <button type="button" class="format-btn active" data-format="csv">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="3" width="18" height="18" rx="2" />
                                    <line x1="3" y1="9" x2="21" y2="9" />
                                    <line x1="3" y1="15" x2="21" y2="15" />
                                    <line x1="9" y1="9" x2="9" y2="21" />
                                </svg>
                                CSV
                            </button>
                            <button type="button" class="format-btn" data-format="xlsx">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                                    <polyline points="14,2 14,8 20,8" />
                                    <path d="M8 13l2 2 4-4" />
                                </svg>
                                Excel (XLSX)
                            </button>
                        </div>
                        <p class="field-hint excel-hint hidden">Excel output limited to @maxExcelMB MB input</p>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Header Row</label>
                        <div class="radio-group">
                            <label class="radio-option">
                                <input type="radio" name="hasHeader" id="hasHeaderNo" value="false" checked />
                                <span class="radio-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12" /></svg></span>
                                <span class="radio-label"><strong>No header</strong><small>Columns: Column1, Column2</small></span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="hasHeader" id="hasHeaderYes" value="true" />
                                <span class="radio-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12" /></svg></span>
                                <span class="radio-label"><strong>First row is header</strong><small>Row 1 used as column names</small></span>
                            </label>
                        </div>
                    </div>

                    <div class="info-box">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        <div>
                            <strong>All numerics preserved as text</strong>
                            <p>Numbers, phone numbers with leading <code>0</code>, and large IDs are written exactly â€” no scientific notation, no dropped zeros.</p>
                        </div>
                    </div>
                </div>

                <!-- Upload panel -->
                <div class="panel upload-panel">
                    <div class="panel-header">
                        <svg class="panel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="16,16 12,12 8,16" />
                            <line x1="12" y1="12" x2="12" y2="21" />
                            <path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3" />
                        </svg>
                        <h2>Upload TXT File</h2>
                    </div>
                    <div id="convDropZone" class="drop-zone" tabindex="0" role="button">
                        <div class="drop-zone-content">
                            <div class="drop-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <polyline points="16,16 12,12 8,16" />
                                    <line x1="12" y1="12" x2="12" y2="21" />
                                    <path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3" />
                                </svg>
                            </div>
                            <p class="drop-title">Drop TXT file here</p>
                            <p class="drop-sub">or click to browse</p>
                            <p class="drop-limit">Max @maxMB MB &nbsp;&bull;&nbsp; .txt .csv .tsv .dat .log</p>
                        </div>
                        <input type="file" id="convFileInput" accept=".txt,.csv,.tsv,.dat,.log" hidden />
                    </div>
                    <div id="convFileInfo" class="file-info hidden">
                        <div class="file-info-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                                <polyline points="14,2 14,8 20,8" />
                            </svg>
                        </div>
                        <div class="file-info-text">
                            <span id="convFileName" class="file-name"></span>
                            <span id="convFileSize" class="file-size"></span>
                        </div>
                        <button class="btn-clear" id="convClearFile" title="Clear">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="18" y1="6" x2="6" y2="18" />
                                <line x1="6" y1="6" x2="18" y2="18" />
                            </svg>
                        </button>
                    </div>
                    <button id="convertBtn" class="btn-convert" disabled>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="23,4 23,10 17,10" />
                            <polyline points="1,20 1,14 7,14" />
                            <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15" />
                        </svg>
                        <span id="convertBtnText">Convert</span>
                    </button>
                    <div id="convProgress" class="progress-section hidden">
                        <div class="progress-header">
                            <span class="progress-label" id="convProgLabel">Processing...</span>
                            <div class="progress-actions">
                                <span class="progress-percent" id="convProgPct">0%</span>
                                <button class="btn-cancel" id="convCancelBtn">Cancel</button>
                            </div>
                        </div>
                        <div class="progress-bar-wrap">
                            <div class="progress-bar-fill" id="convProgBar" style="width:0%">
                                <div class="progress-bar-shimmer"></div>
                            </div>
                        </div>
                        <div class="progress-stats">
                            <span id="convRowsStat"></span>
                            <span id="convBytesStat"></span>
                        </div>
                    </div>
                    <div id="convResult" class="result-section hidden">
                        <div id="convSuccessCard" class="result-success hidden">
                            <div class="result-icon success-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20,6 9,17 4,12" />
                                </svg>
                            </div>
                            <div class="result-text">
                                <strong>Conversion complete</strong>
                                <span id="convResultStats"></span>
                            </div>
                            <button class="btn-download" id="convDownloadBtn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="8,17 12,21 16,17" />
                                    <line x1="12" y1="12" x2="12" y2="21" />
                                    <path d="M20.88 18.09A5 5 0 0018 9h-1.26A8 8 0 103 16.29" />
                                </svg>
                                Download
                            </button>
                        </div>
                        <div id="convErrorCard" class="result-error hidden">
                            <div class="result-icon error-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10" />
                                    <line x1="15" y1="9" x2="9" y2="15" />
                                    <line x1="9" y1="9" x2="15" y2="15" />
                                </svg>
                            </div>
                            <div class="result-text">
                                <strong>Error</strong>
                                <span id="convErrMsg"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Preview + DB Insert (shown after conversion) -->
            <div id="convPreview" class="panel preview-panel hidden"></div>
            <div id="convDbPanel" class="panel db-panel hidden"></div>
        </div>

        <!-- â•â• TAB: IMPORT CSV/EXCEL -->
        <div id="tab-import" class="tab-pane hidden">
            <div class="converter-grid">

                <!-- Import config panel -->
                <div class="panel config-panel">
                    <div class="panel-header">
                        <svg class="panel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="3" />
                            <path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14" />
                        </svg>
                        <h2>Import Settings</h2>
                    </div>

                    <div class="field-group" id="impDelimGroup">
                        <label class="field-label">CSV Delimiter <span class="field-hint" style="display:inline">(CSV only)</span></label>
                        <div class="delimiter-row">
                            <select id="impDelimiterSelect" class="styled-select">
                                <option value=",">Comma (standard CSV)</option>
                                <option value="~">~ Tilde</option>
                                <option value="|">| Pipe</option>
                                <option value=";">; Semicolon</option>
                                <option value="tab">-> Tab</option>
                                <option value="custom">Custom</option>
                            </select>
                            <input type="text" id="impCustomDelimiter" class="styled-input custom-delim-input hidden"
                                   placeholder="Enter delimiter" maxlength="5" />
                        </div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Header Row</label>
                        <div class="radio-group">
                            <label class="radio-option">
                                <input type="radio" name="impHasHeader" id="impHasHeaderNo" value="false" checked />
                                <span class="radio-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12" /></svg></span>
                                <span class="radio-label"><strong>No header</strong><small>Columns: Column1, Column2â€¦</small></span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="impHasHeader" id="impHasHeaderYes" value="true" />
                                <span class="radio-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12" /></svg></span>
                                <span class="radio-label"><strong>First row is header</strong><small>Row 1 used as column names</small></span>
                            </label>
                        </div>
                    </div>

                    <div class="info-box">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        <div>
                            <strong>Supported formats</strong>
                            <p>CSV (.csv), Tab-separated (.tsv), Excel (.xlsx/.xls). All column values inserted as <code>NVARCHAR(MAX)</code> text.</p>
                        </div>
                    </div>
                </div>

                <!-- Import upload panel -->
                <div class="panel upload-panel">
                    <div class="panel-header">
                        <svg class="panel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="16,16 12,12 8,16" />
                            <line x1="12" y1="12" x2="12" y2="21" />
                            <path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3" />
                        </svg>
                        <h2>Upload CSV / Excel</h2>
                    </div>

                    <div id="impDropZone" class="drop-zone" tabindex="0" role="button">
                        <div class="drop-zone-content">
                            <div class="drop-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <polyline points="16,16 12,12 8,16" />
                                    <line x1="12" y1="12" x2="12" y2="21" />
                                    <path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3" />
                                </svg>
                            </div>
                            <p class="drop-title">Drop CSV or Excel file here</p>
                            <p class="drop-sub">or click to browse</p>
                            <p class="drop-limit">Max @maxMB MB &nbsp;&bull;&nbsp; .csv .tsv .xlsx .xls</p>
                        </div>
                        <input type="file" id="impFileInput" accept=".csv,.tsv,.xlsx,.xls" hidden />
                    </div>

                    <div id="impFileInfo" class="file-info hidden">
                        <div class="file-info-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                                <polyline points="14,2 14,8 20,8" />
                            </svg>
                        </div>
                        <div class="file-info-text">
                            <span id="impFileName" class="file-name"></span>
                            <span id="impFileSize" class="file-size"></span>
                        </div>
                        <button class="btn-clear" id="impClearFile" title="Clear">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="18" y1="6" x2="6" y2="18" />
                                <line x1="6" y1="6" x2="18" y2="18" />
                            </svg>
                        </button>
                    </div>

                    <button id="impUploadBtn" class="btn-convert btn-import" disabled>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="8,17 12,21 16,17" />
                            <line x1="12" y1="12" x2="12" y2="21" />
                            <path d="M20.88 18.09A5 5 0 0018 9h-1.26A8 8 0 103 16.29" />
                        </svg>
                        <span id="impUploadBtnText">Load & Preview</span>
                    </button>

                    <div id="impProgress" class="progress-section hidden">
                        <div class="progress-header">
                            <span class="progress-label">Uploading &amp; readingâ€¦</span>
                        </div>
                        <div class="progress-bar-wrap">
                            <div class="progress-bar-fill imp-bar" style="width:60%;animation:indeterminate 1.5s ease infinite;"></div>
                        </div>
                    </div>
                    <div id="impResult" class="result-section hidden"></div>
                </div>
            </div>

            <!-- Import Preview + DB Insert -->
            <div id="impPreview" class="panel preview-panel hidden"></div>
            <div id="impDbPanel" class="panel db-panel hidden"></div>
        </div>

    </main>

    <footer class="app-footer">
        <p>Bulk Data Engine &mdash; ASP.NET Core 8 &bull; SqlBulkCopy &bull; RFC 4180 &bull; All numerics as text</p>
    </footer>
</div>
